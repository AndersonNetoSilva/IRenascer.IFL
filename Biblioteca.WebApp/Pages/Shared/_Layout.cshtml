@using IFL.WebApp.TagHelpers
@addTagHelper *, IFL.WebApp

@{
    var menuItems = new List<MenuItem>
    {
        new MenuItem { Title = "Home", Url = Url.Page("/Index") },
        new MenuItem
        {
            Title = "Cadastros",
            Children = new List<MenuItem>
            {
                new MenuItem
                {
                    Title = "Gerais",
                    Children = new List<MenuItem>
                    {
                        new MenuItem { Title = "Atletas",               Url = "/Admin/General/Atletas/Index" },
                        new MenuItem { Title = "Colaboradores",         Url = "/Admin/General/Colaboradores/Index" },
                        new MenuItem { Title = "Competições/Eventos",   Url = "/Admin/General/Eventos/Index" },
                        new MenuItem { Title = "Horários",              Url = "/Admin/General/Horarios/Index" },
                        new MenuItem { Title = "Modalidades",           Url = "/Admin/General/Modalidades/Index" }
                    }
                },
                new MenuItem
                {
                    Title = "Operacional",
                    Children = new List<MenuItem>
                    {
                        new MenuItem { Title = "Estatística Competição", Url = "/Admin/General/EstatisticasCompeticao/Index" },
                        new MenuItem { Title = "Graduação", Url = "/Admin/General/Graduacoes/Index" },
                        new MenuItem { Title = "Presença", Url = "/Admin/Livros/Registro/Index" }
                    }
                },
                new MenuItem
                {
                    Title = "Nutricionista",
                    Children = new List<MenuItem>
                    {
                        new MenuItem { Title = "Pesagem", Url = "/Admin/General/Pesagens/Index" },
                        new MenuItem { Title = "Avaliação Nutricional", Url = "/Admin/General/AvaliacoesNutricional/Index" },
                    }
                }
            }
        },
        new MenuItem
        {
            Title = "Relatórios",
            Children = new List<MenuItem>
            {
                new MenuItem
                {
                    Title = "Listagens",
                    Children = new List<MenuItem>
                    {
                        new MenuItem { Title = "Atletas", Url = "/Admin/Relatorios/Atletas/Index" },
                        new MenuItem { Title = "Colaboradores", Url = "/Admin/Relatorios/Colaboradores/Index" },
                        new MenuItem { Title = "Eventos", Url = "/Admin/Relatorios/Eventos/Index" },
                        new MenuItem { Title = "Horários", Url = "/Admin/Relatorios/Horarios/Index" },
                        new MenuItem { Title = "Modalidades", Url = "/Admin/Relatorios/Modalidades/Index" },
                    }
                },
                new MenuItem
                {
                    Title = "Gerenciais",
                    Children = new List<MenuItem>
                    {
                        new MenuItem { Title = "Estatistica de Competição", Url = "/Admin/General/Atletas/FiltroEstatiscaCompeticao" },
                        new MenuItem { Title = "Avaliações Nutricionais", Url = "/Admin/General/AvaliacoesNutricional/FiltroAvaliacaoNutricional" }
                    }
                }
            }
        }
    };
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - IFL.WebApp</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/IFL.WebApp.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">

    <style>
        /* Aumenta a fonte e afasta a navbar para respirar */
        .navbar {
            box-shadow: 0 4px 15px rgba(0, 0, 0, 0.05); /* Sombra suave */
            padding: 15px 0; /* Mais altura na barra */
            border-bottom: 1px solid #eee !important;
        }

        /* -------------------------------------
                   Nível 1 (Barra principal)
                   ------------------------------------- */
        /* Afeta os links diretos gerados pelo TagHelper */
        .navbar-nav .nav-link {
            font-size: 1.15rem; /* Aumenta o tamanho da fonte (aprox 18px) */
            font-weight: 500;
            color: #334155 !important; /* Cor mais sólida e elegante */
            padding: 10px 20px !important;
            margin: 0 5px;
            border-radius: 8px; /* Cantos arredondados no hover */
            transition: all 0.25s ease-in-out;
        }

            .navbar-nav .nav-link:hover,
            .navbar-nav .nav-item.show .nav-link {
                background-color: #f8f9fa; /* Fundo cinza bem claro ao passar o mouse */
                color: #722f37 !important; /* Cor vinho/bordô do seu logo */
            }

        /* -------------------------------------
                   Nível 2 e 3 (Caixas de Submenu)
                   ------------------------------------- */
        /* Estilo da caixa que abre */
        .dropdown-menu {
            border: none;
            border-radius: 12px;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);
            padding: 10px;
            margin-top: 12px;
            min-width: 250px; /* Mais largo para acomodar a fonte maior */
        }

        /* Estilo dos links dentro da caixa */
        .dropdown-item {
            font-size: 1.05rem; /* Fonte maior para os submenus (aprox 17px) */
            border-radius: 8px;
            padding: 12px 20px;
            color: #475569;
            transition: all 0.2s;
        }

            .dropdown-item:hover,
            .dropdown-item:focus {
                background-color: #fff1f2; /* Fundo vinho bem clarinho */
                color: #722f37;
                transform: translateX(5px); /* Efeito amigável: empurra o texto pra direita */
            }

        /* -------------------------------------
                   Correção de posicionamento para o Nível 3
                   ------------------------------------- */
        .dropdown-submenu {
            position: relative;
        }

            .dropdown-submenu > .dropdown-menu {
                top: 0;
                left: 100%;
                margin-top: -10px;
                margin-left: 5px;
            }
    </style>

</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow mb-3">
            <div class="container">

                <div class="flex items-center gap-2 text-wine-900 cursor-pointer">
                    <svg xmlns="http://www.w3.org/2000/svg"
                         style="vertical-align:sub!important;"
                         width="24"
                         height="24"
                         viewBox="0 0 24 24"
                         fill="none"
                         stroke="currentColor"
                         stroke-width="2"
                         stroke-linecap="round"
                         stroke-linejoin="round"
                         class="lucide lucide-book fill-wine-900"
                         aria-hidden="true">
                        <!-- Capa do livro -->
                        <rect x="3" y="3" width="18" height="18" rx="2" ry="2" />
                        <!-- Lateral da lombada -->
                        <line x1="9" y1="3" x2="9" y2="21" />
                        <!-- Linhas de página -->
                        <line x1="5" y1="7" x2="19" y2="7" />
                        <line x1="5" y1="11" x2="19" y2="11" />
                        <line x1="5" y1="15" x2="19" y2="15" />
                    </svg>

                    <span class="text-2xl font-serif font-bold tracking-tight">
                        <a class="navbar-brand" asp-area="" asp-page="/Index">Instituto Fé na Luta - IFL</a>
                    </span>
                </div>


                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                
                @if (User.Identity.IsAuthenticated)
                {

                    <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                        <menu items="menuItems"></menu>
                        <partial name="_LoginPartial" />
                    </div>            

                }

            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2026 - IFL.WebApp
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)

    <script>
        document.addEventListener("DOMContentLoaded", function () {
            // habilita dropdowns normais do Bootstrap
            var dropdownElementList = [].slice.call(document.querySelectorAll('.dropdown-toggle'))
            dropdownElementList.map(function (dropdownToggleEl) {
                return new bootstrap.Dropdown(dropdownToggleEl)
            });

            // suporte para submenus
            document.querySelectorAll('.dropdown-submenu .dropdown-toggle').forEach(function (element) {
                element.addEventListener('click', function (e) {
                    e.preventDefault();
                    e.stopPropagation();

                    let submenu = this.nextElementSibling;

                    // fecha outros submenus irmãos
                    this.closest('.dropdown-menu')
                        .querySelectorAll('.dropdown-menu.show')
                        .forEach(function (openMenu) {
                            if (openMenu !== submenu) {
                                openMenu.classList.remove('show');
                            }
                        });

                    submenu.classList.toggle('show');
                });
            });

            // Fechar submenus quando dropdown principal fecha
            document.querySelectorAll('.dropdown').forEach(function (dropdown) {
                dropdown.addEventListener('hidden.bs.dropdown', function () {
                    this.querySelectorAll('.dropdown-menu.show').forEach(function (submenu) {
                        submenu.classList.remove('show');
                    });
                });
            });

            // Habilitar hover (opcional)?
            document.querySelectorAll('.dropdown-submenu').forEach(function (submenu) {
                submenu.addEventListener('mouseenter', function () {
                    this.querySelector('.dropdown-menu').classList.add('show');
                });
                submenu.addEventListener('mouseleave', function () {
                    this.querySelector('.dropdown-menu').classList.remove('show');
                });
            });
        });
    </script>

</body>
</html>