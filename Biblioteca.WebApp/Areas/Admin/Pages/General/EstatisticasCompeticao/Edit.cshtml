@page
@model IFL.WebApp.Areas.Admin.Pages.General.EstatisticasCompeticao.EditModel

@{
    ViewData["Title"] = "Alterar Estatísticas";
}

<breadcrumb items="Cadastros, Gerais, Estatisticas Competicao, Alterar"></breadcrumb>

<div class="row justify-content-center mt-4">
    <div class="col-12">
        <div class="card shadow-sm border-0 rounded-3">
            <div class="card-header bg-white border-bottom py-3">
                <h5 class="mb-0 text-primary fw-bold">Alterar Estatísticas da Competição</h5>
            </div>

            <div class="card-body p-4">
                <form method="post" enctype="multipart/form-data">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

                    <input type="hidden" asp-for="EstatisticaCompeticao.Id" />

                    <div class="row mb-4">
                        <div class="col-md-3 mb-3 mb-md-0">
                            <label asp-for="EstatisticaCompeticao.EventoId" class="form-label fw-semibold"></label>
                            <select asp-for="EstatisticaCompeticao.EventoId" asp-items="Model.Eventos" class="form-select bg-light" disabled>
                                <option value="">Selecione</option>
                            </select>
                            <input type="hidden" asp-for="EstatisticaCompeticao.EventoId" />
                            <span asp-validation-for="EstatisticaCompeticao.EventoId" class="text-danger small"></span>
                        </div>

                        <div class="col-md-3 mb-3 mb-md-0">
                            <label asp-for="EstatisticaCompeticao.AtletaId" class="form-label fw-semibold"></label>
                            <select asp-for="EstatisticaCompeticao.AtletaId" asp-items="Model.Atletas" class="form-select bg-light" disabled>
                                <option value="">Selecione</option>
                            </select>
                            <input type="hidden" asp-for="EstatisticaCompeticao.AtletaId" />
                            <span asp-validation-for="EstatisticaCompeticao.AtletaId" class="text-danger small"></span>
                        </div>

                        <div class="col-md-3 mb-3 mb-md-0">
                            <label asp-for="EstatisticaCompeticao.Atleta.Classe" class="form-label fw-semibold"></label>
                            <input asp-for="EstatisticaCompeticao.Atleta.Classe" class="form-control bg-light" readonly />
                        </div>

                        <div class="col-md-3">
                            <label asp-for="EstatisticaCompeticao.Data" class="form-label fw-semibold"></label>
                            <input asp-for="EstatisticaCompeticao.Data" type="date" class="form-control bg-light" readonly />
                        </div>
                    </div>

                    <div class="row mb-2">
                        <div class="col-12">
                            <h6 class="fw-bold text-secondary mb-3"><i class="bi bi-list-ol me-2"></i>Histórico de Lutas</h6>

                            <div class="table-responsive border rounded-3">
                                <table id="tabelaAnexos" class="table table-hover table-sm align-middle mb-0 text-center">
                                    <thead class="table-light">
                                        <tr>
                                            <th style="width: 50px;">
                                                <button type="button" class="btn btn-outline-primary btn-sm" onclick="adicionarDetalhe()" title="Adicionar Luta">
                                                    <i class="bi bi-plus-lg"></i>
                                                </button>
                                            </th>
                                            <th>Vitória</th>
                                            <th>Yuko</th>
                                            <th>Wazari</th>
                                            <th>Ippon</th>
                                            <th>Hansokumake</th>
                                            <th>Shido</th>
                                            <th>Tempo</th>
                                            <th>G. Score</th>
                                            <th>Tempo GS</th>
                                            <th style="min-width: 180px;">Técnica Aplicada</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @for (int i = 0; i < Model.Detalhes.Count; i++)
                                        {
                                            <tr data-index="@i">
                                                <td>
                                                    <button type="button" class="btn btn-outline-danger btn-sm" onclick="marcarParaExclusao(this, 'Detalhes');" title="Excluir Luta">
                                                        <i class="bi bi-trash"></i>
                                                    </button>
                                                    <input type="hidden" asp-for="Detalhes[@i].Id" />
                                                    <input type="hidden" asp-for="Detalhes[@i].MarcadoParaExclusao" />
                                                </td>
                                                <td>
                                                    <div class="form-check d-flex justify-content-center">
                                                        <input asp-for="Detalhes[@i].Vitoria" type="checkbox" class="form-check-input" />
                                                    </div>
                                                </td>
                                                <td>
                                                    <input asp-for="Detalhes[@i].Yuko" class="form-control form-control-sm text-center mx-auto" style="max-width:60px" />
                                                    <span asp-validation-for="Detalhes[@i].Yuko" class="text-danger small"></span>
                                                </td>
                                                <td>
                                                    <input asp-for="Detalhes[@i].Wazari" class="form-control form-control-sm text-center mx-auto" style="max-width:60px" />
                                                    <span asp-validation-for="Detalhes[@i].Wazari" class="text-danger small"></span>
                                                </td>
                                                <td>
                                                    <input asp-for="Detalhes[@i].Ippon" class="form-control form-control-sm text-center mx-auto" style="max-width:60px" />
                                                    <span asp-validation-for="Detalhes[@i].Ippon" class="text-danger small"></span>
                                                </td>
                                                <td>
                                                    <input asp-for="Detalhes[@i].Hansokumake" class="form-control form-control-sm text-center mx-auto" style="max-width:100px" />
                                                    <span asp-validation-for="Detalhes[@i].Hansokumake" class="text-danger small"></span>
                                                </td>
                                                <td>
                                                    <input asp-for="Detalhes[@i].Shido" class="form-control form-control-sm text-center mx-auto" style="max-width:60px" />
                                                    <span asp-validation-for="Detalhes[@i].Shido" class="text-danger small"></span>
                                                </td>

                                                <td>
                                                    <input asp-for="Detalhes[@i].TempoDaLuta" type="time" class="form-control form-control-sm mx-auto" style="max-width:110px" />
                                                </td>

                                                <td>
                                                    <div class="form-check d-flex justify-content-center">
                                                        <input asp-for="Detalhes[@i].GoldenScore" type="checkbox" class="form-check-input" />
                                                    </div>
                                                </td>

                                                <td>
                                                    <input asp-for="Detalhes[@i].TempoDoGoldenScore" type="time" class="form-control form-control-sm mx-auto" style="max-width:110px" />
                                                </td>

                                                <td>
                                                    <select asp-for="Detalhes[@i].TecnicaAplicou" class="form-select form-select-sm" asp-items="Html.GetEnumSelectList<IFL.WebApp.Model.Tecnica>()">
                                                        <option value="">Selecione</option>
                                                    </select>
                                                    <span asp-validation-for="Detalhes[@i].TecnicaAplicou" class="text-danger small"></span>
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>

                    <hr class="text-muted mb-4 mt-4" />

                    <div class="d-flex justify-content-end gap-2">
                        <a asp-page="./Index" class="btn btn-light border px-4">Voltar</a>
                        <button type="submit" class="btn btn-primary px-4">Gravar Alterações</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        const opcoesTecnica = `
            <option value="">Selecione uma técnica</option>
            @foreach (var item in Html.GetEnumSelectList<IFL.WebApp.Model.Tecnica>())
            {
                    <option value="@item.Value">@item.Text</option>
            }
        `;

        let contadorAnexo = `@Model.Detalhes.Count`;

        function adicionarDetalhe() {
            const tbody = document.querySelector('#tabelaAnexos tbody');
            const novaLinha = document.createElement('tr');

            novaLinha.innerHTML = `
                <td>
                    <button type="button" class="btn btn-outline-danger btn-sm p-1" onclick="marcarParaExclusao(this, 'Detalhes');">
                        <i class="bi bi-trash"></i>
                    </button>
                    <input type="hidden" name="Detalhes[${contadorAnexo}].Id" value="0"/>
                    <input type="hidden" name="Detalhes[${contadorAnexo}].MarcadoParaExclusao" value="false"/>
                </td>
                <td>
                    <div class="form-check d-flex justify-content-center">
                        <input type="checkbox" data-val="true" data-val-required="The Vitoria field is required." name="Detalhes[${contadorAnexo}].Vitoria" value="true" class="form-check-input">
                    </div>
                </td>
                <td>
                    <input name="Detalhes[${contadorAnexo}].Yuko" class="form-control form-control-sm text-center mx-auto" style="max-width:60px" />
                    <span class="text-danger small field-validation-valid" data-valmsg-for="Detalhes[${contadorAnexo}].Yuko" data-valmsg-replace="true"></span>
                </td>
                <td>
                    <input name="Detalhes[${contadorAnexo}].Wazari" class="form-control form-control-sm text-center mx-auto" style="max-width:60px"/>
                    <span class="text-danger small field-validation-valid" data-valmsg-for="Detalhes[${contadorAnexo}].Wazari" data-valmsg-replace="true"></span>
                </td>
                <td>
                    <input name="Detalhes[${contadorAnexo}].Ippon" class="form-control form-control-sm text-center mx-auto" style="max-width:60px" />
                    <span class="text-danger small field-validation-valid" data-valmsg-for="Detalhes[${contadorAnexo}].Ippon" data-valmsg-replace="true"></span>
                </td>
                <td>
                    <input name="Detalhes[${contadorAnexo}].Hansokumake" class="form-control form-control-sm text-center mx-auto" style="max-width:100px" />
                    <span class="text-danger small field-validation-valid" data-valmsg-for="Detalhes[${contadorAnexo}].Hansokumake" data-valmsg-replace="true"></span>
                </td>
                <td>
                    <input name="Detalhes[${contadorAnexo}].Shido" class="form-control form-control-sm text-center mx-auto" style="max-width:60px" />
                    <span class="text-danger small field-validation-valid" data-valmsg-for="Detalhes[${contadorAnexo}].Shido" data-valmsg-replace="true"></span>
                </td>

                <td>
                    <input name="Detalhes[${contadorAnexo}].TempoDaLuta" type="time" class="form-control form-control-sm mx-auto" style="max-width:110px"/>
                </td>

                <td>
                    <div class="form-check d-flex justify-content-center">
                        <input type="checkbox" data-val="true" data-val-required="The Golden Score field is required." name="Detalhes[${contadorAnexo}].GoldenScore" value="true" class="form-check-input">
                    </div>
                </td>

                <td>
                    <input name="Detalhes[${contadorAnexo}].TempoDoGoldenScore" type="time" class="form-control form-control-sm mx-auto" style="max-width:110px"/>
                </td>

                <td>
                    <select name="Detalhes[${contadorAnexo}].TecnicaAplicou" id="Detalhes[${contadorAnexo}].TecnicaAplicou" class="form-select form-select-sm w-100">
                        ${opcoesTecnica}
                    </select>
                    <span class="text-danger small field-validation-valid" data-valmsg-for="Detalhes[${contadorAnexo}].TecnicaAplicou" data-valmsg-replace="true"></span>
                </td>
            `;

            tbody.appendChild(novaLinha);
            contadorAnexo++;
        }

        function marcarParaExclusao(button, arrayName) {
            const row = button.closest('tr');
            const hidden = row.querySelector(`input[type="hidden"][name^="${arrayName}["][name$=".MarcadoParaExclusao"]`);

            if (!hidden) return;

            hidden.value = "true";
            row.classList.add('table-danger', 'text-muted');
            button.disabled = true;
        };
    </script>
}