@page
@model IFL.WebApp.Areas.Admin.Pages.General.Modalidades.CreateModel

@{
    ViewData["Title"] = "Inserir Modalidade";
}

<breadcrumb items="Cadastros, Gerais, Modalidades, Inserir"></breadcrumb>

<div class="row justify-content-center mt-4">
    <div class="col-md-10 col-lg-8">

        <div class="card shadow-sm border-0 rounded-3">
            <div class="card-header bg-white border-bottom py-3">
                <h5 class="mb-0 text-primary fw-bold">Cadastrar Nova Modalidade</h5>
            </div>

            <div class="card-body p-4">
                <form method="post">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

                    <div class="row mb-3">
                        <div class="col-md-9 mb-3 mb-md-0">
                            <label asp-for="Modalidade.Nome" class="form-label fw-semibold"></label>
                            <input asp-for="Modalidade.Nome" class="form-control" placeholder="Ex: Natação, Musculação..." />
                            <span asp-validation-for="Modalidade.Nome" class="text-danger small"></span>
                        </div>

                        <div class="col-md-3 d-flex align-items-center pt-md-4">
                            <div class="form-check form-switch">
                                <input asp-for="Modalidade.Ativo" class="form-check-input" type="checkbox" role="switch" checked="checked" />
                                <label asp-for="Modalidade.Ativo" class="form-check-label fw-semibold"></label>
                                <span asp-validation-for="Modalidade.Ativo" class="text-danger small"></span>
                            </div>
                        </div>
                    </div>

                    <div class="row mb-4">
                        <div class="col-12">
                            <label asp-for="Modalidade.Descricao" class="form-label fw-semibold"></label>
                            <textarea asp-for="Modalidade.Descricao"
                                      class="form-control"
                                      rows="4"
                                      placeholder="Descreva os detalhes desta modalidade..."></textarea>
                            <span asp-validation-for="Modalidade.Descricao" class="text-danger small"></span>
                        </div>
                    </div>

                    <hr class="text-muted mb-4" />

                    <div class="d-flex justify-content-end gap-2">
                        <a asp-page="./Index" class="btn btn-light border px-4">Voltar</a>
                        <button type="submit" class="btn btn-primary px-4">Gravar Modalidade</button>
                    </div>
                </form>
            </div>
        </div>

    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}